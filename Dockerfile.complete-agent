# 🏥 Complete Healthcare Automation Agent
# Integrates full LEADSPRINT-AI-AGENT-INSTRUCTIONS.md workflow

FROM node:18-slim

# Install system dependencies for complete automation
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    git \
    curl \
    rsync \
    wget \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Chrome for Puppeteer
RUN wget -q -O - https://dl-ssl.google.com/linux/linux_signing_key.pub | apt-key add - \
    && sh -c 'echo "deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main" >> /etc/apt/sources.list.d/google.list' \
    && apt-get update \
    && apt-get install -y google-chrome-stable fonts-ipafont-gothic fonts-wqy-zenhei fonts-thai-tlwg fonts-kacst fonts-freefont-ttf libxss1 \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# Install Python MCP dependencies
RUN pip3 install --no-cache-dir \
    mcp \
    aiohttp \
    requests \
    asyncio-compat

# Set working directory
WORKDIR /app

# Copy package files and install Node.js dependencies
COPY package*.json ./
RUN npm install --only=production

# Install additional packages for complete automation
RUN npm install puppeteer express cors axios

# Copy all application files (complete template)
COPY . .

# Copy the complete automation agent
COPY autonomous-healthcare-agent-complete.js ./

# Copy working Python MCP scripts
COPY railway_mcp_complete.py ./
COPY railway_mcp_with_github.py ./

# Configure git for repository operations
RUN git config --global user.email "automation@leadsprint.ai" && \
    git config --global user.name "Leadsprint AI Agent"

# Environment variables
ENV NODE_ENV=production
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3001/health || exit 1

# Expose port
EXPOSE 3001

# Start the complete automation agent
CMD ["node", "autonomous-healthcare-agent-complete.js"]